# BridgeAgent config example
#
# ⚠  TESTNET AGENT WALLET ONLY.
# ⚠  Never paste your main wallet's private key here.
#
# These keys are normally written by `bridgeagent setup`, which runs the
# Byreal Perps CLI bootstrap and reads the resulting agent key from
# ~/.byreal-perps/perps.db.
#
# Manual setup (advanced): paste an existing perps-venue agent wallet here.
# Generate one at the perps testnet API page: https://app.hyperliquid-testnet.xyz/API.
# Agent wallets can place trades for your main account but CANNOT withdraw
# funds. Revocable any time from the same page.
#
# The wizard writes this file at ~/.config/bridgeagent/.env.

BRIDGE_NETWORK=testnet
BRIDGE_MAIN_ADDRESS=0x_your_main_wallet_public_address
BRIDGE_AGENT_PRIVATE_KEY=0x_agent_wallet_private_key

# Mantle Sepolia (chain 5003) — required for ERC-8004 identity NFT mint and
# TradeJournal mirror writes. Faucet: https://faucet.sepolia.mantle.xyz
MANTLE_RPC_URL=https://rpc.sepolia.mantle.xyz
MANTLE_PRIVATE_KEY=0x_separate_funded_key_for_mantle_gas
MANTLE_IDENTITY_REGISTRY=0x_deployed_address
MANTLE_TRADE_JOURNAL=0x_deployed_address

# Optional: AWS Bedrock creds for Claude trade explanations.
# Leave blank to run without AI.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# Optional: HypeDexer API key. Required only for the Liquidation
# Cascade v2 strategy; the other strategies work without it.
HYPEDEXER_API_KEY=
